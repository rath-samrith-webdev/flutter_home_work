# Firebase - Shared
PROJECT_ID=your-project-id
MESSAGING_SENDER_ID=your-sender-id
STORAGE_BUCKET=your-project.firebasestorage.app

# Firebase - Web
WEB_API_KEY=your-web-api-key
WEB_APP_ID=your-web-app-id
AUTH_DOMAIN=your-project.firebaseapp.com
WEB_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase - Android
ANDROID_API_KEY=your-android-api-key
ANDROID_APP_ID=your-android-app-id
ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Firebase - iOS
IOS_API_KEY=your-ios-api-key
IOS_APP_ID=your-ios-app-id
IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
IOS_BUNDLE_ID=com.your.bundle
